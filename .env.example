# G2 Data API key — get from https://data.g2.com/api/docs
G2_API_KEY=your_g2_api_token_here

# Optional: override the default Flask port
PORT=5000

# Supabase — persistent cloud storage for proposals
# Create a free project at https://supabase.com, run supabase-schema.sql,
# then copy URL and anon key from Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here
