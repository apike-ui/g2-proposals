# ============================================
# AI CPQ + HubSpot - Environment Variables
# ============================================

# Session Secret (REQUIRED - minimum 32 characters)
SESSION_SECRET=change-this-to-a-random-string-minimum-32-characters

# Admin Credentials (defaults shown - change for production)
ADMIN_USERNAME=JamesPike
# Set this to a bcrypt hash of your password. Generate with: node scripts/hash-password.js
# Default fallback: Soccer123
ADMIN_PASSWORD_HASH=

# ---- Supabase (FREE tier at supabase.com) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- HubSpot (FREE CRM at hubspot.com) ----
# Create a Private App at: Settings > Integrations > Private Apps
# Required scopes: crm.objects.contacts.read, crm.objects.deals.write,
#                  crm.objects.products.write, crm.objects.products.read
HUBSPOT_ACCESS_TOKEN=your-hubspot-private-app-token

# ---- Anthropic Claude API (Optional - for AI features) ----
# Get your key at: console.anthropic.com
# AI features will be disabled if not set
ANTHROPIC_API_KEY=

# App URL (update for production deployment)
NEXT_PUBLIC_APP_URL=http://localhost:3000
